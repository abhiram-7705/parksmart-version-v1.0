{
  "name": "com.cts.mfrp.parksmart.repository.BookingsRepository",
  "module": "JPA",
  "type": "IMPERATIVE",
  "methods": [
    {
      "name": "existsActiveOrUpcomingBySlotId",
      "signature": "public abstract boolean com.cts.mfrp.parksmart.repository.BookingsRepository.existsActiveOrUpcomingBySlotId(java.lang.Integer)",
      "query": {
        "query": "SELECT COUNT(b) > 0 FROM Bookings b\nWHERE b.parkingSlot.slotId = :slotId\nAND b.status IN ('CONFIRMED','UPCOMING','ACTIVE')\n"
      }
    },
    {
      "name": "existsActiveOrUpcomingBySpaceId",
      "signature": "public abstract boolean com.cts.mfrp.parksmart.repository.BookingsRepository.existsActiveOrUpcomingBySpaceId(java.lang.Integer)",
      "query": {
        "query": "SELECT COUNT(b) > 0 FROM Bookings b\nJOIN b.parkingSlot s\nWHERE s.parkingSpace.spaceId = :spaceId\nAND b.status IN ('CONFIRMED','UPCOMING','ACTIVE')\n"
      }
    },
    {
      "name": "existsByParkingSlotSlotIdAndArrivalLessThanAndLeavingGreaterThan",
      "signature": "public abstract boolean com.cts.mfrp.parksmart.repository.BookingsRepository.existsByParkingSlotSlotIdAndArrivalLessThanAndLeavingGreaterThan(java.lang.Integer,java.time.LocalDateTime,java.time.LocalDateTime)",
      "query": {
        "query": "SELECT b.bookingId FROM Bookings b WHERE b.parkingSlot.slotId = :slotId AND b.arrival < :arrival AND b.leaving > :leaving"
      }
    },
    {
      "name": "findBySpaceId",
      "signature": "public abstract java.util.List<com.cts.mfrp.parksmart.model.Bookings> com.cts.mfrp.parksmart.repository.BookingsRepository.findBySpaceId(java.lang.Integer)",
      "query": {
        "query": "SELECT b FROM Bookings b\nJOIN b.parkingSlot s\nWHERE s.parkingSpace.spaceId = :spaceId\nORDER BY b.arrival DESC\n"
      }
    },
    {
      "name": "findByUserId",
      "signature": "public abstract java.util.List<com.cts.mfrp.parksmart.model.Bookings> com.cts.mfrp.parksmart.repository.BookingsRepository.findByUserId(int)",
      "query": {
        "query": "SELECT b FROM Bookings b WHERE b.user.userId = :userId ORDER BY b.arrival DESC"
      }
    },
    {
      "name": "findSuggestionsByUserAndQuery",
      "signature": "public abstract java.util.List<java.lang.String> com.cts.mfrp.parksmart.repository.BookingsRepository.findSuggestionsByUserAndQuery(java.lang.String,java.lang.String)",
      "query": {
        "query": "SELECT ps.name\nFROM Bookings b\nJOIN b.parkingSlot s\nJOIN s.parkingSpace ps\nWHERE b.user.email = :email\nAND (\n    LOWER(ps.name) LIKE LOWER(CONCAT('%', :query, '%')) OR\n    LOWER(ps.location) LIKE LOWER(CONCAT('%', :query, '%')) OR\n    LOWER(ps.city) LIKE LOWER(CONCAT('%', :query, '%'))\n)\n"
      }
    },
