  "methods": [
    {
      "name": "findByOwnerUserId",
      "signature": "public abstract java.util.List<com.cts.mfrp.parksmart.model.ParkingSpaces> com.cts.mfrp.parksmart.repository.ParkingSpacesRepository.findByOwnerUserId(int)",
      "query": {
        "query": "SELECT p FROM ParkingSpaces p WHERE p.owner.userId = :userId"
      }
    },
    {
      "name": "findBySpaceIdAndOwnerUserId",
      "signature": "public abstract java.util.Optional<com.cts.mfrp.parksmart.model.ParkingSpaces> com.cts.mfrp.parksmart.repository.ParkingSpacesRepository.findBySpaceIdAndOwnerUserId(java.lang.Integer,int)",
      "query": {
        "query": "SELECT p FROM ParkingSpaces p WHERE p.spaceId = :spaceId AND p.owner.userId = :userId"
      }
    },
    {
      "name": "findFirstByLocationIgnoreCaseAndCityIgnoreCase",
      "signature": "public abstract com.cts.mfrp.parksmart.model.ParkingSpaces com.cts.mfrp.parksmart.repository.ParkingSpacesRepository.findFirstByLocationIgnoreCaseAndCityIgnoreCase(java.lang.String,java.lang.String)",
      "query": {
        "query": "SELECT p FROM ParkingSpaces p WHERE UPPER(p.location) = UPPER(:loc) AND UPPER(p.city) = UPPER(:city)"
      }
    },
    {
      "name": "findLocationSuggestions",
      "signature": "public abstract java.util.List<java.lang.String> com.cts.mfrp.parksmart.repository.ParkingSpacesRepository.findLocationSuggestions(java.lang.String)",
      "query": {
        "query": "    SELECT DISTINCT CONCAT(p.location, ', ', p.city)\n    FROM ParkingSpaces p\n    WHERE LOWER(p.location) LIKE LOWER(CONCAT('%', :query, '%'))\n       OR LOWER(p.city) LIKE LOWER(CONCAT('%', :query, '%'))\n"
      }
    },
