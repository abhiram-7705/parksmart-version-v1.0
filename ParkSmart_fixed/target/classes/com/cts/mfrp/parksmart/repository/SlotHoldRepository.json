  "methods": [
    {
      "name": "deleteByExpiresAtBefore",
      "signature": "public abstract void com.cts.mfrp.parksmart.repository.SlotHoldRepository.deleteByExpiresAtBefore(java.time.LocalDateTime)",
      "query": {
        "query": "SELECT s FROM SlotHold s WHERE s.expiresAt < :time"
      }
    },
    {
      "name": "deleteByHoldGroupIdAndUserEmail",
      "signature": "public abstract void com.cts.mfrp.parksmart.repository.SlotHoldRepository.deleteByHoldGroupIdAndUserEmail(java.lang.String,java.lang.String)",
      "query": {
        "query": "SELECT s FROM SlotHold s LEFT JOIN s.user u WHERE s.holdGroupId = :holdGroupId AND u.email = :email"
      }
    },
    {
      "name": "existsBySlotSlotIdAndArrivalLessThanAndLeavingGreaterThanAndExpiresAtAfter",
      "signature": "public abstract boolean com.cts.mfrp.parksmart.repository.SlotHoldRepository.existsBySlotSlotIdAndArrivalLessThanAndLeavingGreaterThanAndExpiresAtAfter(java.lang.Integer,java.time.LocalDateTime,java.time.LocalDateTime,java.time.LocalDateTime)",
      "query": {
        "query": "SELECT s.holdId FROM SlotHold s WHERE s.slot.slotId = :slotId AND s.arrival < :arrival AND s.leaving > :leaving AND s.expiresAt > :now"
      }
    },
    {
      "name": "findByHoldGroupId",
      "signature": "public abstract java.util.List<com.cts.mfrp.parksmart.model.SlotHold> com.cts.mfrp.parksmart.repository.SlotHoldRepository.findByHoldGroupId(java.lang.String)",
      "query": {
        "query": "SELECT s FROM SlotHold s WHERE s.holdGroupId = :holdGroupId"
      }
    },
